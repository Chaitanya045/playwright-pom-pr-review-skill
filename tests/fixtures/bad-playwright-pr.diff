new file mode 100644
index 0000000..1111111
--- /dev/null
+++ b/tests/patients.spec.ts
@@ -0,0 +1,23 @@
+import { test, expect } from '@playwright/test';
+import { PatientsPage } from '../src/pages/PatientsPage';
+
+let patientsPage: any;
+
+test.beforeAll(async ({ page }) => {
+  patientsPage = new PatientsPage(page);
+  await page.goto('/patients');
+});
+
+test('creates patient', async ({ page }) => {
+  const patientsPage = new PatientsPage(page);
+  await page.locator('#root > div:nth-child(2) button.primary').click();
+  await page.waitForTimeout(2000);
+  const patient = JSON.parse('{"name":"John"}') as Patient;
+  await patientsPage.modal.fillForm(patient);
+  await patientsPage.modal.save({ force: true });
+  expect(await page.locator('.toast').isVisible()).toBe(true);
+});
+
+test.skip('updates patient', async ({ page }) => {
+  await page.pause();
+});
